# Copy to .env and fill in. .env is gitignored — never commit real keys.
# HydraDB API key from dashboard.hydradb.com (format: sk_live_...).
HYDRA_DB_API_KEY=sk_live_your_key_here
# OpenRouter API key for the Claude reasoning call (format: sk-or-v1-...).
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Optional: override the reasoning model (default anthropic/claude-sonnet-4.6).
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
